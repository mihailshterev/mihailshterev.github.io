{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://mihailshterev.github.io",
  "type": "module",
  "scripts": {
    "predeploy": "npm run build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "framer-motion": "12.34.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "gh-pages": "6.3.0",
    "globals": "17.6.0",
    "sass-embedded": "1.97.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "7.3.5"
  },
  "packageManager": "pnpm@11.0.6",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.6",
      "onFail": "download"
    }
  }
}
